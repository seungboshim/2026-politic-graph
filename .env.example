# DB 연결 — Vercel 마켓플레이스 통합(Neon/Supabase 등)이 자동 주입합니다.
#   `vercel install neon`(또는 supabase) → `vercel env pull .env.local`
# 런타임은 풀드 URL, db:push(마이그레이션)는 직결(unpooled) URL을 자동 선택합니다.
#   Neon:     DATABASE_URL,  DATABASE_URL_UNPOOLED
#   Supabase: POSTGRES_URL,  POSTGRES_URL_NON_POOLING
DATABASE_URL=

# 댓글 신원/IP 해시용 솔트 — DB 통합이 주지 않으므로 직접 설정(랜덤 문자열).
IP_SALT=any-random-string
